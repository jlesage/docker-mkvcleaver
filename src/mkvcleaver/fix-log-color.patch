# Wine/RichEdit treats RTF \cf0 as "auto" (often black). Keep existing colour
# indices (\cf1/\cf2/\cf3) unchanged; append white as \cf4 and use that where
# the log used \cf0 for default message text.
#
--- a/64 bit/Portable/MKVcleaver.au3	2026-07-17 14:21:54.282017974 +0000
+++ b/64 bit/Portable/MKVcleaver.au3	2026-07-17 14:21:54.292058993 +0000
@@ -2799,7 +2799,7 @@
 			$sLines = "{\rtf1\ansi\ansicpg1252\deff0\nouicompat\deflang1033{\fonttbl{\f0\fnil\fcharset0 Courier;}{\f1\fnil\fcharset0 MS Shell Dlg;}}" & @CRLF & _
 					"{\colortbl\red200\green200\blue200;\red" & _ColorGetRed($sColor1) & "\green" & _ColorGetGreen($sColor1) & "\blue" & _ColorGetBlue($sColor1) & _
 					";\red" & _ColorGetRed($sColor2) & "\green" & _ColorGetGreen($sColor2) & "\blue" & _ColorGetBlue($sColor2) & _
-					";\red" & _ColorGetRed($sColor3) & "\green" & _ColorGetGreen($sColor3) & "\blue" & _ColorGetBlue($sColor3) & ";}" & @CRLF & _
+					";\red" & _ColorGetRed($sColor3) & "\green" & _ColorGetGreen($sColor3) & "\blue" & _ColorGetBlue($sColor3) & ";\red255\green255\blue255;}" & @CRLF & _
 					"{\*\generator Riched20 10.0.26100}\viewkind4\uc1" & @CRLF & _
 					"\pard\cf1\f0\fs20 "
 		EndIf
@@ -2810,13 +2810,13 @@
 
 		Switch $aRow[2]
 			Case 1
-				Local $color = "{\cf0 "
+				Local $color = "{\cf4 "
 			Case 2
 				Local $color = "{\cf2 "
 			Case 3
 				Local $color = "{\cf3 "
 			Case Else
-				Local $color = "{\cf0 "
+				Local $color = "{\cf4 "
 		EndSwitch
 
 		Local $aChars = StringToASCIIArray($aRow[3], Default, Default, 0)
