+; Enable/disable Extract based on DB selection. Uses GetChecked only for the
+; Timecodes-only edge case (Wine-friendly; does not rely on TVN_ITEMCHANGED).
+Func __Sync_Go_Button()
+	Local $iBatch = 0, $iChild = 0
+	_SQLite_QuerySingleRow($db, "select count(rowid) from batch_item_handles where selected='True';", $query_result)
+	$iBatch = Number($query_result[0])
+	_SQLite_QuerySingleRow($db, "select count(rowid) from child_handles where selected='True';", $query_result2)
+	$iChild = Number($query_result2[0])
+	If $iBatch = 0 And $iChild = 0 Then
+		$go_go = 0
+		GUICtrlSetState($go, $GUI_DISABLE)
+	ElseIf $iBatch = 1 And $iChild = 0 And _GUICtrlTreeView_GetChecked($tracklist, $timecodes) = True Then
+		; Selecting only Timecodes is not enough to start extraction.
+		$go_go = 0
+		GUICtrlSetState($go, $GUI_DISABLE)
+	Else
+		$go_go = 1
+		GUICtrlSetState($go, $GUI_ENABLE)
+	EndIf
+EndFunc   ;==>__Sync_Go_Button
+
+Func __Sync_Remove_Button()
+	_SQLite_QuerySingleRow($db, "select count(rowid) from sessions where selected='True';", $query_result)
+	If Number($query_result[0]) = 0 Then
+		GUICtrlSetState($removemkvs, $GUI_DISABLE)
+	Else
+		GUICtrlSetState($removemkvs, $GUI_ENABLE)
+	EndIf
+EndFunc   ;==>__Sync_Remove_Button
+
+; Apply the same checked state to all tree items whose label shares the same
+; first word (e.g. "Video", "Audio"). Used for Shift+click multi-select.
+Func __TreeView_CheckSameType($hTree, $iCtrlId, $sTable, $sHandleCol = "handle")
+	Local $hSelected = GUICtrlGetHandle($iCtrlId)
+	Local $bChecked = _GUICtrlTreeView_GetChecked($hTree, $iCtrlId)
+	Local $aType = StringSplit(_GUICtrlTreeView_GetText($hTree, $iCtrlId), " ", 1)
+	If $aType[0] < 1 Then Return
+	Local $hItem = _GUICtrlTreeView_GetFirstItem($hTree)
+	Do
+		Local $aNext = StringSplit(_GUICtrlTreeView_GetText($hTree, $hItem), " ", 1)
+		If $aNext[0] >= 1 And $aNext[1] == $aType[1] Then
+			_GUICtrlTreeView_SetChecked($hTree, $hItem, $bChecked)
+			_SQLite_Exec($db, "update " & $sTable & " set selected='" & $bChecked & "' where " & $sHandleCol & "='" & $hItem & "';")
+		EndIf
+		$hItem = _GUICtrlTreeView_GetNextSibling($hTree, $hItem)
+	Until $hItem = 0
+EndFunc   ;==>__TreeView_CheckSameType
